{
  "info": {
    "name": "Book Store API",
    "description": "RESTful API for online bookstore with ratings and reviews",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/users/register"
          }
        },
        {
          "name": "Login (Session)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/users/login"
          }
        },
        {
          "name": "Login (JWT)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/users/login-jwt"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/logout"
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/books"
          }
        },
        {
          "name": "Search by ISBN",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/books/isbn/978-0-06-112008-4"
          }
        },
        {
          "name": "Search by Author",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/books/author/Harper%20Lee"
          }
        },
        {
          "name": "Search by Title",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/books/title/Gatsby"
          }
        },
        {
          "name": "Get Book with Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/books/1/reviews"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Get All Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reviews"
          }
        },
        {
          "name": "Get Reviews for Book",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reviews/book/1"
          }
        },
        {
          "name": "Add Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookId\": 1,\n  \"rating\": 5,\n  \"comment\": \"Excellent book! Highly recommended.\"\n}"
            },
            "url": "{{base_url}}/reviews"
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 4,\n  \"comment\": \"Updated comment - still great.\"\n}"
            },
            "url": "{{base_url}}/reviews/1"
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/reviews/1"
          }
        },
        {
          "name": "Get My Reviews",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reviews/user/my-reviews"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ]
}
